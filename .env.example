# 3PL Egypt — copy to .env and fill in values for local dev
# Never commit .env. Real secrets live in your secret manager (AWS Secrets Manager, etc.)

# ---- Postgres ----
POSTGRES_USER=threepl
POSTGRES_PASSWORD=threepl_dev_pwd
POSTGRES_DB=threepl_egypt
POSTGRES_PORT=5432
DATABASE_URL=postgresql://threepl:threepl_dev_pwd@localhost:5432/threepl_egypt?schema=public

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- API ----
API_PORT=3001
NODE_ENV=development
# JWT secrets — generate strong random values for prod
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long_string
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- TOTP / 2FA ----
TOTP_ISSUER=3PL-Egypt

# ---- Web ----
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:3001

# ---- Egypt-specific defaults ----
DEFAULT_TZ=Africa/Cairo
DEFAULT_LOCALE=ar-EG
VAT_RATE_BPS=1400
# EG: VAT stored as basis points (1400 bps = 14%) to avoid float math
