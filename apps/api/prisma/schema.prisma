// 3PL Egypt — primary Prisma schema
// All EGP amounts stored as Int (piastres). Never use Float / Decimal-as-string.
// All timestamps are UTC at rest; display layer converts to Africa/Cairo.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums (mirror packages/shared/src/enums.ts) ----------

enum UserRoleName {
  SUPER_ADMIN
  WAREHOUSE_MANAGER
  PICKER
  DRIVER
  FINANCE
  CLIENT
}

enum GovernorateCode {
  ALX
  ASN
  AST
  BH
  BNS
  C
  DK
  DT
  FYM
  GH
  GZ
  IS
  KB
  KFS
  KN
  LX
  MN
  MNF
  MT
  PTS
  BA
  SHG
  SHR
  SIN
  JS
  SUZ
  WAD
}

enum OrderState {
  PENDING
  PICKED
  PACKED
  DISPATCHED
  DELIVERED
  FAILED
  RETURNED
}

enum PaymentMethod {
  COD
  INSTAPAY
  FAWRY
  BANK_TRANSFER
  WALLET
}

enum IntakeSource {
  SHOPIFY
  WOOCOMMERCE
  SALLA
  ZID
  CSV
  MANUAL
  API
}

enum KycDocType {
  COMMERCIAL_REGISTRATION
  TAX_CARD
  NATIONAL_ID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  MFA_ENROL
  MFA_VERIFY
  STATE_TRANSITION
}

enum CodLedgerType {
  COLLECTED
  REMITTED
  ADJUSTMENT
}

// ---------- WMS enums ----------

enum ZoneType {
  RECEIVING
  STORAGE
  PACKING
  DISPATCH
}

enum LocationType {
  BIN
  RACK
  SHELF
  FLOOR
}

enum StockStatus {
  AVAILABLE
  QUARANTINE
  DAMAGED
}

enum MovementType {
  RECEIPT
  PUTAWAY
  PICK
  ADJUSTMENT
  TRANSFER
  QUARANTINE
  RELEASE
  DISPOSAL
  COUNT_ADJUST
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

// NB: InspectionResult is a transient receiving input (not persisted on a model),
// so it lives as a TS enum in the inbound module rather than here — Prisma only
// generates enums referenced by a model.

enum CycleCountStatus {
  OPEN
  COUNTED
  RECONCILED
}

// ---------- Admin / RBAC ----------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  phone           String?   @unique
  passwordHash    String
  fullName        String
  isActive        Boolean   @default(true)
  // EG: regional managers are scoped to a subset of governorates.
  // Empty list = no governorate scope restriction (e.g. Super Admin, head-office Finance).
  scopedGovernorates GovernorateCode[] @default([])
  // For role=CLIENT users, links to the Client they belong to.
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  mfaSecret       MfaSecret?
  roles           UserRole[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  driverRemittances DriverRemittance[]
  driverProfile   DriverProfile?
  shipmentsAsDriver Shipment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
}

model Role {
  id          String      @id @default(cuid())
  name        UserRoleName @unique
  description String?
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime    @default(now())
}

model Permission {
  id          String  @id @default(cuid())
  /// dot-namespaced key, e.g. "orders.read", "users.write", "audit.read"
  key         String  @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model MfaSecret {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// base32-encoded TOTP secret
  secret    String
  /// has the user completed the enrol-then-verify handshake
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(rawToken) — never store the raw token
  tokenHash   String    @unique
  deviceLabel String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  /// "user", "order", "client", etc.
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ---------- Client & Contract ----------

model Client {
  id                  String         @id @default(cuid())
  legalName           String
  tradingName         String?
  taxId               String?        @unique
  commercialRegistration String?     @unique
  contactName         String
  contactEmail        String
  contactPhone        String
  /// EG: invoicing address — full Egyptian address breakdown
  addressApartment    String?
  addressFloor        String?
  addressBuilding     String?
  addressStreet       String?
  addressDistrict     String?
  governorate         GovernorateCode
  /// COD commission %, expressed in basis points (e.g. 250 = 2.50%)
  isActive            Boolean        @default(true)
  kycDocuments        KycDocument[]
  contracts           Contract[]
  users               User[]
  orders              Order[]
  skus                Sku[]
  purchaseOrders      PurchaseOrder[]
  wallet              ClientWallet?
  payouts             Payout[]
  invoices            Invoice[]
  returnRequests      ReturnRequest[]
  creditNotes         CreditNote[]
  importShipments     ImportShipment[]
  storeConnections    StoreConnection[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([governorate])
}

model KycDocument {
  id          String     @id @default(cuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        KycDocType
  fileUrl     String
  uploadedAt  DateTime   @default(now())
  /// who reviewed/approved
  reviewedBy  String?
  reviewedAt  DateTime?
  approved    Boolean?   // null = pending review

  @@index([clientId])
}

model Contract {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startsOn        DateTime
  endsOn          DateTime?
  /// Pricing — all amounts in piastres
  storagePerSkuPerDayPiastres Int @default(0)
  pickAndPackPiastres         Int @default(0)
  /// COD commission % in basis points
  codCommissionBps            Int @default(250)
  /// Return fee in piastres
  returnFeePiastres           Int @default(0)
  sla             Sla?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientId])
}

model Sla {
  id                       String    @id @default(cuid())
  contractId               String    @unique
  contract                 Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  handlingTimeMinutes      Int       @default(240)
  deliveryWindowDaysCairo  Int       @default(2)
  deliveryWindowDaysOther  Int       @default(4)
  /// max return rate allowed, in basis points (e.g. 500 = 5.00%)
  maxReturnRateBps         Int       @default(500)
}

// ---------- WMS: warehouses, zones, locations, inventory ----------

model Warehouse {
  id           String          @id @default(cuid())
  code         String          @unique
  name         String
  governorate  GovernorateCode
  isActive     Boolean         @default(true)
  /// EG: bonded zone — duty/VAT on imported goods is deferred until release
  isBonded     Boolean         @default(false)
  orders       Order[]
  zones        Zone[]
  locations    Location[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  cycleCounts  CycleCount[]
  importShipments ImportShipment[]
  createdAt    DateTime        @default(now())

  @@index([governorate])
}

model Zone {
  id          String     @id @default(cuid())
  warehouseId String
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  type        ZoneType
  code        String
  name        String
  locations   Location[]
  createdAt   DateTime   @default(now())

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model Location {
  id          String       @id @default(cuid())
  zoneId      String
  zone        Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  /// denormalised for fast warehouse-scoped queries
  warehouseId String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String
  type        LocationType @default(BIN)
  /// scannable location barcode for handheld terminals
  barcode     String?
  isActive    Boolean      @default(true)
  stockLevels StockLevel[]
  createdAt   DateTime     @default(now())

  @@unique([warehouseId, code])
  @@index([zoneId])
  @@index([barcode])
}

model Sku {
  id            String       @id @default(cuid())
  /// client-scoped SKU code (unique per client)
  code          String
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nameAr        String
  nameEn        String?
  /// EAN-13 / UPC barcode, if any
  barcode       String?
  /// EG: Harmonized System tariff code (for customs duty lookup on imports)
  hsCode        String?
  /// Default unit price for invoicing displays (in piastres). Real selling price comes from the order line.
  defaultUnitPricePiastres Int @default(0)
  /// unit of measure, e.g. EA (each), BOX, KG
  unitOfMeasure String       @default("EA")
  /// EG: FMCG/pharma need expiry tracking → enables FEFO picking + lot capture on receipt
  expiryTracked Boolean      @default(false)
  /// low-stock alert threshold (total available across locations)
  reorderPointQty Int        @default(0)
  isActive      Boolean      @default(true)
  orderItems    OrderItem[]
  lots          Lot[]
  stockLevels   StockLevel[]
  stockMovements StockMovement[]
  cycleCounts   CycleCount[]
  poLines       PoLine[]
  returnItems   ReturnItem[]
  importLines   ImportShipmentLine[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([clientId, code])
  @@index([clientId])
  @@index([barcode])
}

model Lot {
  id          String       @id @default(cuid())
  skuId       String
  sku         Sku          @relation(fields: [skuId], references: [id], onDelete: Cascade)
  lotNumber   String
  /// EG: expiry drives FEFO (first-expired-first-out) picking
  expiryDate  DateTime?
  stockLevels StockLevel[]
  createdAt   DateTime     @default(now())

  @@unique([skuId, lotNumber])
  @@index([skuId])
  @@index([expiryDate])
}

model StockLevel {
  id         String      @id @default(cuid())
  skuId      String
  sku        Sku         @relation(fields: [skuId], references: [id], onDelete: Cascade)
  locationId String
  location   Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lotId      String?
  lot        Lot?        @relation(fields: [lotId], references: [id], onDelete: SetNull)
  status     StockStatus @default(AVAILABLE)
  quantity   Int         @default(0)
  updatedAt  DateTime    @updatedAt

  @@index([skuId])
  @@index([locationId])
  @@index([skuId, status])
}

model StockMovement {
  id             String       @id @default(cuid())
  warehouseId    String
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id])
  skuId          String
  sku            Sku          @relation(fields: [skuId], references: [id])
  lotId          String?
  fromLocationId String?
  toLocationId   String?
  quantity       Int
  type           MovementType
  status         StockStatus  @default(AVAILABLE)
  /// optional links for traceability
  orderId        String?
  purchaseOrderId String?
  actorId        String?
  note           String?
  createdAt      DateTime     @default(now())

  @@index([warehouseId])
  @@index([skuId])
  @@index([createdAt])
}

// ---------- WMS: inbound ----------

model PurchaseOrder {
  id           String              @id @default(cuid())
  reference    String              @unique
  clientId     String
  client       Client              @relation(fields: [clientId], references: [id])
  warehouseId  String
  warehouse    Warehouse           @relation(fields: [warehouseId], references: [id])
  supplierName String?
  status       PurchaseOrderStatus @default(DRAFT)
  expectedDate DateTime?
  notes        String?
  lines        PoLine[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([clientId])
  @@index([warehouseId])
  @@index([status])
}

model PoLine {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  skuId            String
  sku              Sku           @relation(fields: [skuId], references: [id])
  quantityOrdered  Int
  quantityReceived Int           @default(0)
  /// optional lot/expiry captured at PO time (else captured on receipt)
  lotNumber        String?
  expiryDate       DateTime?

  @@index([purchaseOrderId])
}

// ---------- WMS: cycle counting ----------

model CycleCount {
  id           String           @id @default(cuid())
  warehouseId  String
  warehouse    Warehouse        @relation(fields: [warehouseId], references: [id])
  locationId   String
  skuId        String
  sku          Sku              @relation(fields: [skuId], references: [id])
  status       CycleCountStatus @default(OPEN)
  expectedQty  Int
  countedQty   Int?
  varianceQty  Int?
  countedById  String?
  createdAt    DateTime         @default(now())
  reconciledAt DateTime?

  @@index([warehouseId])
  @@index([status])
}

model Order {
  id              String         @id @default(cuid())
  /// Client-facing reference shown on packing slip, comms, etc.
  reference       String         @unique
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id])
  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  intakeSource    IntakeSource
  /// Raw payload from the source (Shopify webhook, CSV row, etc.) — kept for traceability.
  intakePayload   Json?
  /// External reference from the source system (Shopify order id, Salla order id, etc.)
  externalRef     String?
  state           OrderState     @default(PENDING)
  // ---- end customer ----
  customerName    String
  customerPhone   String
  customerPhoneAlt String?
  // ---- delivery address ----
  addressApartment String?
  addressFloor     String?
  addressBuilding  String?
  addressStreet    String?
  addressDistrict  String?
  governorate     GovernorateCode
  notes           String?
  // ---- payment ----
  paymentMethod   PaymentMethod
  /// gross amount the courier will collect on COD; null for prepaid orders
  codAmountPiastres Int?
  /// 3PL service-fee total (piastres, VAT-inclusive)
  serviceFeePiastres Int           @default(0)
  /// flagged by validation (duplicate, fraud heuristic, etc.)
  flaggedReason    String?
  items           OrderItem[]
  transitions     OrderStateTransition[]
  codLedger       CodLedgerEntry[]
  shipment        Shipment?
  returns         ReturnRequest[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clientId])
  @@index([warehouseId])
  @@index([governorate])
  @@index([state])
  @@index([createdAt])
  @@index([externalRef])
  @@index([customerPhone])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId         String
  sku           Sku     @relation(fields: [skuId], references: [id])
  quantity      Int
  /// unit price snapshot in piastres at the time the order was created
  unitPricePiastres Int

  @@index([orderId])
}

model OrderStateTransition {
  id        String     @id @default(cuid())
  orderId   String
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromState OrderState?
  toState   OrderState
  /// user id of the actor (nullable for system transitions, e.g. courier webhook)
  actorId   String?
  reason    String?
  createdAt DateTime   @default(now())

  @@index([orderId])
}

model CodLedgerEntry {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type           CodLedgerType
  /// integer piastres; positive amounts collected/remitted
  amountPiastres Int
  /// actor (driver/finance) who recorded this entry
  actorId        String?
  note           String?
  createdAt      DateTime      @default(now())

  @@index([orderId])
  @@index([createdAt])
}

// ---------- COD & Finance ----------

enum WalletEntryType {
  COD_CREDIT      // gross COD collected, credited to the client
  COMMISSION_FEE  // 3PL commission incl. VAT, debited
  PAYOUT          // funds paid out to the client
  ADJUSTMENT
}

enum RemittanceStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum PayoutRail {
  INSTAPAY
  FAWRY
  SWIFT
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

model ClientWallet {
  id              String        @id @default(cuid())
  clientId        String        @unique
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  /// EG: running balance in piastres; equals the sum of entries.
  balancePiastres Int           @default(0)
  entries         WalletEntry[]
  payouts         Payout[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model WalletEntry {
  id             String          @id @default(cuid())
  walletId       String
  wallet         ClientWallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type           WalletEntryType
  /// signed: credits positive, debits negative
  amountPiastres Int
  orderId        String?
  remittanceId   String?
  payoutId       String?
  note           String?
  createdAt      DateTime        @default(now())

  @@index([walletId])
  @@index([createdAt])
}

model DriverRemittance {
  id                      String           @id @default(cuid())
  reference               String           @unique
  driverId                String
  driver                  User             @relation(fields: [driverId], references: [id])
  status                  RemittanceStatus @default(PENDING)
  /// cash the driver declares depositing
  declaredAmountPiastres  Int
  /// total COD across the covered orders, confirmed by finance
  confirmedAmountPiastres Int?
  confirmedById           String?
  confirmedAt             DateTime?
  note                    String?
  items                   RemittanceItem[]
  createdAt               DateTime         @default(now())

  @@index([driverId])
  @@index([status])
}

model RemittanceItem {
  id                String           @id @default(cuid())
  remittanceId      String
  remittance        DriverRemittance @relation(fields: [remittanceId], references: [id], onDelete: Cascade)
  /// snapshot — an order's COD can only be remitted once
  orderId           String           @unique
  clientId          String
  codAmountPiastres Int

  @@index([remittanceId])
}

model Payout {
  id             String       @id @default(cuid())
  reference      String       @unique
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  walletId       String
  wallet         ClientWallet @relation(fields: [walletId], references: [id])
  amountPiastres Int
  rail           PayoutRail
  status         PayoutStatus @default(PENDING)
  /// external transfer reference (Instapay/Fawry/SWIFT)
  externalRef    String?
  createdById    String?
  createdAt      DateTime     @default(now())
  paidAt         DateTime?

  @@index([clientId])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  reference     String        @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  periodStart   DateTime
  periodEnd     DateTime
  status        InvoiceStatus @default(DRAFT)
  netPiastres   Int           @default(0)
  vatPiastres   Int           @default(0)
  grossPiastres Int           @default(0)
  /// EG: ETA e-invoice UUID once submitted to the Egyptian Tax Authority portal
  etaUuid       String?
  lines         InvoiceLine[]
  createdAt     DateTime      @default(now())
  issuedAt      DateTime?

  @@index([clientId])
  @@index([status])
}

model InvoiceLine {
  id              String  @id @default(cuid())
  invoiceId       String
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description     String
  quantity        Int     @default(1)
  unitNetPiastres Int
  netPiastres     Int
  vatPiastres     Int
  grossPiastres   Int

  @@index([invoiceId])
}

// ---------- Last-Mile & Fleet ----------

enum CarrierType {
  COURIER
  IN_HOUSE
}

enum ShipmentStatus {
  PENDING            // created, not yet assigned
  ASSIGNED           // courier label created / driver assigned
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum PodMethod {
  PHOTO
  SIGNATURE
  OTP
}

enum DeliveryFailureReason {
  CUSTOMER_UNREACHABLE
  ADDRESS_NOT_FOUND
  CUSTOMER_REFUSED
  POSTPONED
  OTHER
}

model DriverProfile {
  id          String            @id @default(cuid())
  userId      String            @unique
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType String?
  plateNumber String?
  isAvailable Boolean           @default(true)
  /// EG: governorates this driver serves (for in-house assignment)
  zones       GovernorateCode[] @default([])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Shipment {
  id             String         @id @default(cuid())
  reference      String         @unique
  orderId        String         @unique
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrierType    CarrierType
  /// set when carrierType = COURIER
  courierId      String?
  courierAccount CourierAccount? @relation(fields: [courierId], references: [id])
  /// set when carrierType = IN_HOUSE
  driverId       String?
  driver         User?          @relation(fields: [driverId], references: [id])
  trackingNumber String?
  status         ShipmentStatus @default(PENDING)
  /// denormalised from the order for zone queries
  governorate    GovernorateCode
  attemptCount   Int            @default(0)
  scheduledFor   DateTime?
  /// hashed delivery OTP + expiry (POD via OTP)
  podOtpHash     String?
  podOtpExpiresAt DateTime?
  attempts       DeliveryAttempt[]
  pod            ProofOfDelivery?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([governorate])
  @@index([driverId])
  @@index([courierId])
}

model DeliveryAttempt {
  id            String                 @id @default(cuid())
  shipmentId    String
  shipment      Shipment               @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  attemptNumber Int
  success       Boolean
  failureReason DeliveryFailureReason?
  note          String?
  actorId       String?
  createdAt     DateTime               @default(now())

  @@index([shipmentId])
}

model ProofOfDelivery {
  id            String    @id @default(cuid())
  shipmentId    String    @unique
  shipment      Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  method        PodMethod
  photoUrl      String?
  signatureUrl  String?
  otpVerified   Boolean   @default(false)
  recipientName String?
  capturedById  String?
  capturedAt    DateTime  @default(now())
}

/// A carrier integration that can be onboarded at runtime (credentials encrypted at rest).
model CourierAccount {
  id                  String            @id @default(cuid())
  /// short code, e.g. ARAMEX, BOSTA (stable identifier used in labels + i18n)
  code                String            @unique
  name                String
  apiBaseUrl          String?
  /// AES-256-GCM ciphertext (never returned to clients)
  apiKeyEncrypted     String?
  webhookSecretEncrypted String?
  isActive            Boolean           @default(true)
  shipments           Shipment[]
  coverage            CourierCoverage[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model CourierCoverage {
  id            String          @id @default(cuid())
  courierId     String
  courierAccount CourierAccount @relation(fields: [courierId], references: [id], onDelete: Cascade)
  governorate   GovernorateCode
  etaDays       Int             @default(3)
  isServiceable Boolean         @default(true)

  @@unique([courierId, governorate])
  @@index([governorate])
}

enum StorePlatform {
  SHOPIFY
  WOOCOMMERCE
  SALLA
  ZID
}

enum StoreConnectionStatus {
  PENDING    // OAuth initiated, awaiting callback
  CONNECTED  // token stored, receiving webhooks
  REVOKED    // disconnected / uninstalled
}

/// A seller's e-commerce storefront linked via OAuth. Order webhooks resolve the client by shopDomain.
model StoreConnection {
  id                     String                @id @default(cuid())
  clientId               String
  client                 Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform               StorePlatform
  /// canonical store host, e.g. acme.myshopify.com / acme.salla.sa (resolves inbound webhooks → client)
  shopDomain             String                @unique
  status                 StoreConnectionStatus @default(PENDING)
  /// AES-256-GCM ciphertext (never returned to clients)
  accessTokenEncrypted   String?
  /// per-store secret for verifying inbound webhook HMAC
  webhookSecretEncrypted String?
  scopes                 String?
  /// CSRF nonce echoed back on the OAuth callback
  oauthState             String?
  installedAt            DateTime?
  lastEventAt            DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([clientId])
}

// ---------- Returns (reverse logistics) ----------

enum ReturnReason {
  DAMAGED
  WRONG_ITEM
  CUSTOMER_REFUSAL
  CHANGE_OF_MIND
}

enum ReturnStatus {
  REQUESTED   // raised by customer/ops, awaiting approval
  APPROVED    // RMA issued
  RECEIVED    // goods back at the warehouse
  INSPECTED   // each item dispositioned
  CLOSED      // credit note issued, order marked returned
  REJECTED
}

enum ReturnDisposition {
  RESELLABLE  // back to available stock
  DAMAGED     // to quarantine, pending disposal approval
}

model ReturnRequest {
  id           String        @id @default(cuid())
  rmaNumber    String        @unique
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  reason       ReturnReason
  status       ReturnStatus  @default(REQUESTED)
  /// free-text note from the end customer (Arabic-first portal)
  customerNote String?
  approvedById String?
  receivedAt   DateTime?
  inspectedAt  DateTime?
  closedAt     DateTime?
  items        ReturnItem[]
  creditNote   CreditNote?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orderId])
  @@index([clientId])
  @@index([status])
}

model ReturnItem {
  id              String             @id @default(cuid())
  returnRequestId String
  returnRequest   ReturnRequest      @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  skuId           String
  sku             Sku                @relation(fields: [skuId], references: [id])
  quantity        Int
  /// unit price snapshot from the original order line (piastres)
  unitPricePiastres Int
  /// set at inspection
  disposition     ReturnDisposition?
  /// location the resellable/damaged stock was put into
  restockLocationId String?
  disposalApproved  Boolean          @default(false)

  @@index([returnRequestId])
}

model CreditNote {
  id              String           @id @default(cuid())
  reference       String           @unique
  returnRequestId String           @unique
  returnRequest   ReturnRequest    @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  netPiastres     Int
  vatPiastres     Int
  grossPiastres   Int
  lines           CreditNoteLine[]
  createdAt       DateTime         @default(now())

  @@index([clientId])
}

model CreditNoteLine {
  id              String     @id @default(cuid())
  creditNoteId    String
  creditNote      CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  description     String
  quantity        Int
  unitNetPiastres Int
  netPiastres     Int
  vatPiastres     Int
  grossPiastres   Int

  @@index([creditNoteId])
}

// ---------- Customs & Compliance (importers) ----------

enum ImportStatus {
  DRAFT
  DECLARED          // ECA declaration number assigned
  UNDER_INSPECTION
  CLEARED           // duties/VAT assessed + paid
  RELEASED          // goods received into the warehouse
  CANCELLED
}

/// Harmonized System tariff reference for duty lookup.
model HsCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  /// import duty rate in basis points (1400 = 14%)
  dutyRateBps Int      @default(0)
  createdAt   DateTime @default(now())
}

model ImportShipment {
  id                   String               @id @default(cuid())
  reference            String               @unique
  clientId             String
  client               Client               @relation(fields: [clientId], references: [id])
  warehouseId          String?
  warehouse            Warehouse?           @relation(fields: [warehouseId], references: [id])
  /// EG: Egyptian Customs Authority declaration number
  ecaDeclarationNumber String?
  status               ImportStatus         @default(DRAFT)
  originCountry        String?
  supplierName         String?
  /// CIF components, in piastres
  freightCostPiastres   Int                 @default(0)
  insuranceCostPiastres Int                 @default(0)
  /// whether goods are held in a bonded zone (duty deferred until release)
  bonded               Boolean              @default(false)
  declaredAt           DateTime?
  clearedAt            DateTime?
  releasedAt           DateTime?
  lines                ImportShipmentLine[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([clientId])
  @@index([status])
}

model ImportShipmentLine {
  id               String         @id @default(cuid())
  importShipmentId String
  importShipment   ImportShipment @relation(fields: [importShipmentId], references: [id], onDelete: Cascade)
  skuId            String
  sku              Sku            @relation(fields: [skuId], references: [id])
  /// HS code snapshot at declaration time
  hsCode           String
  /// duty rate snapshot (bps) at declaration time
  dutyRateBps      Int            @default(0)
  quantity         Int
  /// goods unit cost (FOB), in piastres
  unitCostPiastres Int

  @@index([importShipmentId])
}

// ---------- Notifications & Communications ----------

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  INTERNAL   // in-app operational alert
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationCategory {
  ORDER_UPDATE
  DELIVERY
  RETURN
  LOW_STOCK
  SLA_BREACH
  FAILED_DELIVERY_SPIKE
  DIGEST
  OTHER
}

enum SmsProvider {
  VODAFONE
  ETISALAT
}

model Notification {
  id            String               @id @default(cuid())
  channel       NotificationChannel
  category      NotificationCategory @default(OTHER)
  /// phone (SMS/WhatsApp), email address, or a role/user label for INTERNAL
  recipient     String
  locale        String               @default("ar")
  subject       String?
  body          String
  status        NotificationStatus   @default(PENDING)
  /// SMS provider used, when channel = SMS
  provider      SmsProvider?
  /// provider message id (stub)
  providerRef   String?
  error         String?
  relatedEntity String?
  relatedId     String?
  createdAt     DateTime             @default(now())
  sentAt        DateTime?

  @@index([channel])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}
